root = true

[*.cs]

indent_style = space
indent_size = 4
insert_final_newline = true

# Remove unused usings
dotnet_diagnostic.CS8019.severity = none
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true

# Disable AutoMapper vulnerability warning
dotnet_diagnostic.NU1903.severity = none

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped

# Nullability
nullable = enable

# Readonly fields
dotnet_style_readonly_field = true

# Naming rules
dotnet_naming_rule.interface_should_start_with_i.severity = suggestion
dotnet_naming_rule.interface_should_start_with_i.symbols = interface_symbols
dotnet_naming_rule.interface_should_start_with_i.style = begins_with_i

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.begins_with_i.capitalization = pascal_case
dotnet_naming_style.begins_with_i.required_prefix = I

dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion
dotnet_naming_rule.types_should_be_pascal_case.symbols = type_symbols
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.type_symbols.applicable_kinds = class, struct, interface, enum
dotnet_naming_style.pascal_case_style.capitalization = pascal_case
